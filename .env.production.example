# CherryOps Backend — Production Environment Variables
# Copy to .env and fill in values: cp .env.production.example .env

# Required
CHERRYOPS_JWT_SECRET=           # openssl rand -hex 32

# GitHub (for repo file operations)
GITHUB_PAT=                     # GitHub PAT with repo scope

# Optional — AI task execution
ANTHROPIC_API_KEY=              # For api_direct task mode
GEMINI_API_KEY=                 # For voice transcription

# Optional — Push notifications
FIREBASE_SERVICE_ACCOUNT_JSON=  # Firebase Admin SDK JSON

# Optional — GitHub OAuth (for mobile app auth)
GITHUB_OAUTH_CLIENT_ID=         # GitHub OAuth App client ID

# Server
PORT=3100
NODE_ENV=production
