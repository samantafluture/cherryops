# Auth
CHERRYOPS_JWT_SECRET=change-me-to-a-random-secret

# GitHub (PAT for repo read/write)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Firebase (FCM push notifications)
FIREBASE_SERVICE_ACCOUNT_JSON={}

# Gemini (voice transcription)
GEMINI_API_KEY=

# Claude (task execution when agent_mode = cherry_agent)
ANTHROPIC_API_KEY=

# Server
PORT=3100
NODE_ENV=development
